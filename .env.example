# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Quick start (no API key):  ./scripts/dev.sh
# Live local API:            DEMO_MODE=false in .env, then ./scripts/run.sh
# Cloud deploy:              fill GOOGLE_CLOUD_* below, store GEMINI_API_KEY in Secret Manager, then ./scripts/deploy-cloudrun.sh

# =============================================================================
# Gemini API (get key at https://aistudio.google.com/apikey)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.0-flash

# =============================================================================
# Runtime mode
# =============================================================================
# true  = offline demo data (no Gemini calls) — use with ./scripts/dev.sh
# false = live Gemini analysis — requires GEMINI_API_KEY above
DEMO_MODE=true

# true  = use Google ADK agents for trust + code review (needs API key / Vertex)
# false = direct Gemini calls only (faster local dev)
USE_ADK=false

# =============================================================================
# Google Cloud (for deploy + optional Vertex AI)
# =============================================================================
# Your GCP project ID — used by ./scripts/deploy-cloudrun.sh (reads .env automatically)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for Cloud Run deploy (e.g. northamerica-northeast2, us-central1)
GOOGLE_CLOUD_LOCATION=northamerica-northeast2

# Optional alias; deploy script uses GOOGLE_CLOUD_PROJECT if GCP_PROJECT_ID is unset
# GCP_PROJECT_ID=your-gcp-project-id

# =============================================================================
# Vertex AI (optional — instead of GEMINI_API_KEY)
# =============================================================================
GOOGLE_GENAI_USE_VERTEXAI=false
# When true, set GOOGLE_CLOUD_PROJECT + GOOGLE_CLOUD_LOCATION and run:
#   gcloud auth application-default login
