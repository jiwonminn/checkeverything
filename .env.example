# Copy to .env and adjust. For local UI testing without Google Cloud setup, use:
#   ./scripts/dev.sh
# which enables DEMO_MODE automatically.

# --- Local testing (recommended) ---
DEMO_MODE=true
USE_ADK=false
GOOGLE_GENAI_USE_VERTEXAI=false

# --- Live Gemini API (optional) ---
# DEMO_MODE=false
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.0-flash

# --- Vertex AI (optional) ---
# DEMO_MODE=false
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1
# Requires: gcloud auth application-default login
